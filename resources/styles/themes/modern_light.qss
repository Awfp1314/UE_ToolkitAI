    background: transparent;
}

/* ===== 区域标签 ===== */
#SectionLabel {
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
}

/* ===== 输入�?===== */
#EditAssetInput {
    background-color: rgba(0, 0, 0, 0.08);
    border: none;
    border-radius: 8px;
    padding: 0 16px;
