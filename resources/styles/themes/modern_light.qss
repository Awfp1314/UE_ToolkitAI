
/* ===== base.qss ===== */

/* ========================================
   基础样式 - Base Styles
   ======================================== */

/* ===== 全局重置 ===== */
* {
    outline: none;
}

/* ===== 默认字体 ===== */
QWidget {
    font-family: "Microsoft YaHei UI", "Segoe UI", sans-serif;
    font-size: 14px;
}



/* ===== components.qss ===== */

/* ========================================
   通用组件样式 - Common Components
   ======================================== */

/* 此文件用于定义通用组件样式（按钮、输入框、滚动条等）
   目前主窗口样式已�?widgets/main_window.qss 中定�?
   未来可在此添加更多通用组件样式 */

/* ===== 全局滚动条样式（自动隐藏效果�?===== */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0px;
    border: none;
}

QScrollBar::handle:vertical {
    background: rgba(255, 255, 255, 0.05);  /* 默认几乎透明 */
    border-radius: 4px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(0, 0, 0, 0.3);  /* 悬停时显�?*/
}

QScrollBar::handle:vertical:pressed {
    background: rgba(0, 0, 0, 0.4);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

/* 水平滚动�?*/
QScrollBar:horizontal {
    background: transparent;
    height: 8px;
    margin: 0px;
    border: none;
}

QScrollBar::handle:horizontal {
    background: rgba(255, 255, 255, 0.05);  /* 默认几乎透明 */
    border-radius: 4px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background: rgba(0, 0, 0, 0.3);  /* 悬停时显�?*/
}

QScrollBar::handle:horizontal:pressed {
    background: rgba(0, 0, 0, 0.4);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    background: none;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}



/* ===== add_asset_dialog.qss ===== */

/* ===== 添加资产对话框样�?===== */

/* 对话框本�?*/
#AddAssetDialog {
    background-color: transparent;
}

/* 主容�?*/
#AddAssetDialogContainer {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffff,
        stop:1 #f8f8f8
    );
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 0px;
}

/* 标题�?*/
#AddAssetDialogTitleBar {
    background: #f8f8f8;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
}

#AddAssetDialogTitleIcon {
    font-size: 24px;
    padding: 0px 8px;
}

#AddAssetDialogTitleLabel {
    color: #1a1a1a;
    font-size: 16px;
    font-weight: 600;
    padding-left: 5px;
}

/* 内容区域 */
#AddAssetDialogContent {
    background-color: transparent;
}

/* 标签 */
#AddAssetDialogLabel {
    color: rgba(0, 0, 0, 0.7);
    font-size: 13px;
    font-weight: 600;
    padding: 3px 0px;
}

/* 输入�?*/
#AddAssetDialogInput,
#AddAssetDialogPathInput {
    background-color: #f5f5f5;
    border: none;
    border-radius: 8px;
    padding: 10px 15px;
    color: #1a1a1a;
    font-size: 13px;
    selection-background-color: #4a9eff;
}

#AddAssetDialogInput:focus,
#AddAssetDialogPathInput:focus {
    border: none;
    background-color: rgba(0, 0, 0, 0.03);
}

#AddAssetDialogInput::placeholder,
#AddAssetDialogPathInput::placeholder {
    color: rgba(0, 0, 0, 0.45);
}

/* 类型选择下拉框（QComboBox�?*/
QComboBox#AddAssetDialogInput {
    padding-right: 30px;
}

QComboBox#AddAssetDialogInput::drop-down {
    border: none;
    width: 30px;
}

QComboBox#AddAssetDialogInput::down-arrow {
    image: url(:/icons/dropdown_arrow.png);
    width: 12px;
    height: 12px;
}

QComboBox#AddAssetDialogInput QAbstractItemView {
    background-color: #f5f5f5;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    padding: 4px;
    outline: none;
    selection-background-color: #4a9eff;
    selection-color: #1a1a1a;
}

QComboBox#AddAssetDialogInput QAbstractItemView::item {
    height: 32px;
    padding: 4px 12px;
    border-radius: 4px;
    color: #1a1a1a;
}

QComboBox#AddAssetDialogInput QAbstractItemView::item:hover {
    background-color: rgba(0, 0, 0, 0.05);
}

QComboBox#AddAssetDialogInput QAbstractItemView::item:selected {
    background-color: #4a9eff;
    color: #1a1a1a;
}

/* 下拉�?*/
#AddAssetDialogCombo {
    background-color: #f0f0f0;
    border: none;
    border-radius: 8px;
    padding: 10px 15px;
    padding-right: 15px;
    color: #1a1a1a;
    font-size: 13px;
}

#AddAssetDialogCombo:hover {
    border: none;
    background-color: rgba(0, 0, 0, 0.08);
}

#AddAssetDialogCombo:focus {
    border: none;
}

#AddAssetDialogCombo::drop-down {
    border: none;
    width: 0px;
}

#AddAssetDialogCombo::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
}

#AddAssetDialogCombo QAbstractItemView {
    background-color: #f8f8f8;
    border: 1px solid rgba(0, 0, 0, 0.2);
    selection-background-color: #4a9eff;
    selection-color: #1a1a1a;
    color: #1a1a1a;
    padding: 5px;
    outline: none;
}

#AddAssetDialogCombo QAbstractItemView::item {
    padding: 8px 12px;
    border-radius: 4px;
    min-height: 30px;
}

#AddAssetDialogCombo QAbstractItemView::item:hover {
    background-color: rgba(0, 0, 0, 0.08);
}

#AddAssetDialogCombo QAbstractItemView::item:selected {
    background-color: #4a9eff;
}

/* 提示文字 */
#AddAssetDialogHint {
    color: #888888;
    font-size: 12px;
    padding-left: 4px;
}

/* 复选框 */
#AddAssetDialogCheckbox {
    color: #1a1a1a;
    font-size: 13px;
    spacing: 8px;
}

#AddAssetDialogCheckbox::indicator {
    width: 18px;
    height: 18px;
    border: none;
    border-radius: 3px;
    background-color: #f0f0f0;
}

#AddAssetDialogCheckbox::indicator:hover {
    border: none;
    background-color: rgba(0, 0, 0, 0.08);
}

#AddAssetDialogCheckbox::indicator:checked {
    background-color: #4a9eff;
    border: none;
}

/* 错误标签 */
#AddAssetDialogErrorLabel {
    color: #ef4444;
    font-size: 13px;
    font-weight: 600;
    padding: 12px;
    background-color: #f0f0f0;
    border: none;
    border-radius: 8px;
}

/* 浏览按钮 */
#AddAssetDialogBrowseBtn {
    background: #f0f0f0;
    border: none;
    border-radius: 8px;
    color: #1a1a1a;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 18px;
    min-width: 70px;
}

#AddAssetDialogBrowseBtn:hover {
    background: rgba(0, 0, 0, 0.08);
}

#AddAssetDialogBrowseBtn:pressed {
    background: rgba(0, 0, 0, 0.15);
}

/* 取消按钮 */
#AddAssetDialogCancelBtn {
    background-color: #f0f0f0;
    border: none;
    border-radius: 8px;
    color: #1a1a1a;
    font-size: 13px;
    font-weight: 600;
}

#AddAssetDialogCancelBtn:hover {
    background-color: rgba(0, 0, 0, 0.08);
}

#AddAssetDialogCancelBtn:pressed {
    background-color: rgba(0, 0, 0, 0.15);
}

/* 添加按钮 */
#AddAssetDialogAddBtn {
    background: #4a9eff;
    border: none;
    border-radius: 8px;
    color: #1a1a1a;
    font-size: 13px;
    font-weight: 600;
}

#AddAssetDialogAddBtn:hover {
    background: #5aa9ff;
}

#AddAssetDialogAddBtn:pressed {
    background: #3a8eef;
}

/* 右键菜单 */
#AddAssetDialogMenu {
    background-color: #f0f0f0;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 8px;
    padding: 5px;
}

#AddAssetDialogMenu::item {
    color: #1a1a1a;
    padding: 10px 20px;
    border-radius: 4px;
    font-size: 14px;
}

#AddAssetDialogMenu::item:selected {
    background-color: #4a9eff;
}

#AddAssetDialogMenu::item:hover {
    background-color: rgba(0, 0, 0, 0.08);
}


/* ===== asset_path_setup_dialog.qss ===== */

/* ===== 资产库路径设置弹窗样�?===== */

/* 容器 */
#AssetPathSetupDialogContainer {
    background-color: #f8f8f8;
    border: 1px solid rgba(74, 158, 255, 0.3);
    border-radius: 0px;
}

/* 标题�?*/
#AssetPathSetupDialogTitleBar {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(74, 158, 255, 0.2),
        stop:1 rgba(74, 158, 255, 0.1)
    );
    border-bottom: 1px solid rgba(74, 158, 255, 0.3);
}

/* 标题图标 */
#AssetPathSetupDialogTitleIcon {
    color: #4a9eff;
    font-size: 18px;
}

/* 标题文字 */
#AssetPathSetupDialogTitleLabel {
    color: #1a1a1a;
    font-size: 14px;
    font-weight: bold;
}

/* 内容区域 */
#AssetPathSetupDialogContent {
    background-color: #f8f8f8;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
}

/* 描述文字 */
#AssetPathSetupDialogDescription {
    color: rgba(0, 0, 0, 0.7);
    font-size: 13px;
    line-height: 1.5;
}

/* 标签 */
#AssetPathSetupDialogLabel {
    color: #1a1a1a;
    font-size: 13px;
    font-weight: bold;
}

/* 输入�?*/
#AssetPathSetupDialogInput {
    background-color: #ffffff;
    color: #1a1a1a;
    border: none;
    border-radius: 5px;
    padding: 8px 12px;
    font-size: 13px;
}

#AssetPathSetupDialogInput:focus {
    border: none;
    background-color: #f0f0f0;
}

#AssetPathSetupDialogInput::placeholder {
    color: rgba(0, 0, 0, 0.3);
}

/* 浏览按钮 */
#AssetPathSetupDialogBrowseBtn {
    background-color: #f0f0f0;
    color: #1a1a1a;
    border: none;
    border-radius: 5px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: bold;
}

#AssetPathSetupDialogBrowseBtn:hover {
    background-color: rgba(0, 0, 0, 0.08);
}

#AssetPathSetupDialogBrowseBtn:pressed {
    background-color: rgba(0, 0, 0, 0.15);
}

/* 提示文字 */
#AssetPathSetupDialogHint {
    color: rgba(0, 0, 0, 0.55);
    font-size: 12px;
}

#AssetPathSetupDialogHint[valid="true"] {
    color: #4ade80;
}

#AssetPathSetupDialogHint[valid="false"] {
    color: #fbbf24;
}

/* 确认按钮 */
#AssetPathSetupDialogConfirmBtn {
    background-color: #4a9eff;
    color: white;
    border: none;
    border-radius: 5px;
    padding: 10px 28px;
    font-size: 13px;
    font-weight: bold;
}

#AssetPathSetupDialogConfirmBtn:hover {
    background-color: #5aa9ff;
}

#AssetPathSetupDialogConfirmBtn:pressed {
    background-color: #3a8eef;
}

#AssetPathSetupDialogConfirmBtn:disabled {
    background-color: #f0f0f0;
    color: rgba(0, 0, 0, 0.3);
}


/* ===== category_management_dialog.qss ===== */

/* ========================================
   分类管理对话框样�?
   从内联样式迁移到QSS系统
   ======================================== */

/* ===== 对话框容�?===== */
#CategoryDialogContainer {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #f0f0f0,
        stop:0.03 #f8f8f8,
        stop:1 #ffffff);
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 0px;
}

/* ===== 标题�?===== */
#CategoryDialogTitleBar {
    background: transparent;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

#CategoryDialogTitle {
    color: #1a1a1a;
    font-size: 18px;
    font-weight: 700;
    background: transparent;
}

#CategoryDialogCloseButton {
    background: transparent;
    color: rgba(0, 0, 0, 0.7);
    border: none;
    border-radius: 6px;
    font-size: 20px;
    font-weight: 300;
}

#CategoryDialogCloseButton:hover {
    background: rgba(0, 0, 0, 0.08);
    color: #1a1a1a;
}

#CategoryDialogCloseButton:pressed {
    background: rgba(0, 0, 0, 0.15);
}

/* ===== 内容区域 ===== */
#CategoryDialogContent {
    background: transparent;
}

/* ===== 区域标签 ===== */
#SectionLabel {
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
}

/* ===== 输入�?===== */
#CategoryInput {
    background-color: #f0f0f0;
    border: none;
    border-radius: 8px;
    padding: 0 16px;
    color: #1a1a1a;
    font-size: 14px;
}

#CategoryInput:focus {
    background-color: #f8f8f8;
    border: none;
}

#CategoryInput::placeholder {
    color: rgba(0, 0, 0, 0.3);
}

/* ===== 添加按钮 ===== */
#AddButton {
    background-color: #4a9eff;
    color: #1a1a1a;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
}

#AddButton:hover {
    background-color: #5aa9ff;
}

#AddButton:pressed {
    background-color: #3a8eef;
}

/* ===== 错误标签 ===== */
#ErrorLabel {
    color: #ef4444;
    font-size: 13px;
    background: transparent;
}

/* ===== 分类列表 ===== */
#CategoryList {
    background-color: #f0f0f0;
    border: none;
    border-radius: 8px;
    padding: 8px;
    color: #1a1a1a;
    font-size: 14px;
    outline: none;
}

#CategoryList::item {
    padding: 12px 16px;
    border-radius: 6px;
    border: none;
    outline: none;
}

#CategoryList::item:selected {
    background-color: #4a9eff;
    color: #1a1a1a;
}

#CategoryList::item:hover:!selected {
    background-color: rgba(0, 0, 0, 0.08);
}

#CategoryList::item:selected:hover {
    background-color: #5aa9ff;
}

/* ===== 分类列表滚动�?===== */
#CategoryList QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    margin: 0px;
    border: none;
}

#CategoryList QScrollBar::handle:vertical {
    background-color: rgba(0, 0, 0, 0.3);
    border-radius: 4px;
    min-height: 20px;
    border: none;
}

#CategoryList QScrollBar::handle:vertical:hover {
    background-color: rgba(0, 0, 0, 0.5);
}

#CategoryList QScrollBar::add-line:vertical,
#CategoryList QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
    border: none;
}

#CategoryList QScrollBar::add-page:vertical,
#CategoryList QScrollBar::sub-page:vertical {
    background: none;
    border: none;
}

#CategoryList QScrollBar::up-arrow:vertical,
#CategoryList QScrollBar::down-arrow:vertical {
    width: 0px;
    height: 0px;
    background: none;
}

/* ===== 删除按钮 ===== */
#DeleteButton {
    background-color: #ef4444;
    color: #1a1a1a;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
}

#DeleteButton:hover {
    background-color: #f87171;
}

#DeleteButton:pressed {
    background-color: #dc2626;
}

/* ===== 提示信息 ===== */
#InfoLabel {
    color: rgba(0, 0, 0, 0.55);
    font-size: 12px;
    background: transparent;
}


/* ===== chat_input.qss ===== */

/* ========================================
   AI助手聊天输入框样�?
   ======================================== */

/* ===== 聊天区域 ===== */
#ChatScrollArea {
    background-color: transparent;
    border: none;
}

#ChatMessageContainer {
    background-color: transparent;
}

#ChatInputWrapper {
    background-color: transparent;
}

/* ===== 输入框容�?===== */
#ChatInputContainer {
    background-color: #F0F0F0;
    border: none;
    border-radius: 26px;
}

/* ===== 文本输入�?===== */
#ChatInput {
    background-color: transparent;
    border: none;
    color: #0D0D0D;
    font-size: 16px;
    font-weight: 500;
    font-family: "Segoe UI", "Microsoft YaHei UI", "Microsoft YaHei", sans-serif;
    selection-background-color: rgba(16, 163, 127, 0.3);
    padding: 0px 4px;
    line-height: 1.4;
}

#ChatInput:focus {
    outline: none;
}

/* ===== 滚动�?===== */
#ChatInput QScrollBar:vertical {
    background: transparent;
    width: 6px;
    margin: 2px;
}

#ChatInput QScrollBar::handle:vertical {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 3px;
    min-height: 20px;
}

#ChatInput QScrollBar::handle:vertical:hover {
    background: rgba(0, 0, 0, 0.4);
}

#ChatInput QScrollBar::add-line:vertical,
#ChatInput QScrollBar::sub-line:vertical {
    height: 0px;
}

#ChatInput QScrollBar::add-page:vertical,
#ChatInput QScrollBar::sub-page:vertical {
    background: none;
}

/* ===== 按钮样式 ===== */
/* 注意：按钮的背景、悬停效果由 paintEvent 自定义绘�?*/
/* QSS只控制基础属性，不设置background避免覆盖 */
#ChatAddButton {
    border: none;
}

#ChatSendButton {
    border: none;
}


/* ===== confirm_dialog.qss ===== */

/* ===== 确认对话框样�?===== */

/* 对话框本�?*/
#ConfirmDialog {
    background-color: #f8f8f8;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 0px;
}

/* 消息文本 */
#ConfirmDialogMessage {
    color: #1a1a1a;
    font-size: 15px;
    font-weight: bold;
    padding: 10px 5px;
}

/* 详细信息文本 */
#ConfirmDialogDetails {
    color: rgba(0, 0, 0, 0.7);
    font-size: 12px;
    padding: 10px;
    background-color: #ffffff;
    border-radius: 4px;
    border: none;
}

/* 确认按钮 */
#ConfirmDialogOkButton {
    background-color: #4a9eff;
    color: white;
    border: none;
    padding: 10px 28px;
    border-radius: 5px;
    font-size: 13px;
    min-width: 80px;
    font-weight: bold;
}

#ConfirmDialogOkButton:hover {
    background-color: #5aa9ff;
}

#ConfirmDialogOkButton:pressed {
    background-color: #3a8eef;
}

/* 取消按钮 */
#ConfirmDialogCancelButton {
    background-color: #f0f0f0;
    color: #1a1a1a;
    border: none;
    padding: 10px 28px;
    border-radius: 5px;
    font-size: 13px;
    min-width: 80px;
    font-weight: bold;
}

#ConfirmDialogCancelButton:hover {
    background-color: rgba(0, 0, 0, 0.08);
}

#ConfirmDialogCancelButton:pressed {
    background-color: rgba(0, 0, 0, 0.15);
}



/* ===== edit_asset_dialog.qss ===== */

/* ========================================
   编辑资产对话框样�?
   从内联样式迁移到QSS系统
   ======================================== */

/* ===== 对话框容�?===== */
#EditAssetDialogContainer {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #f0f0f0,
        stop:0.03 #f8f8f8,
        stop:1 #ffffff);
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 0px;
}

/* ===== 标题�?===== */
#EditAssetDialogTitleBar {
    background: transparent;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

#EditAssetDialogTitle {
    color: #1a1a1a;
    font-size: 18px;
    font-weight: 700;
    background: transparent;
}

#EditAssetDialogCloseButton {
    background: transparent;
    color: rgba(0, 0, 0, 0.7);
    border: none;
    border-radius: 6px;
    font-size: 20px;
    font-weight: 300;
}

#EditAssetDialogCloseButton:hover {
    background: rgba(0, 0, 0, 0.08);
    color: #1a1a1a;
}

#EditAssetDialogCloseButton:pressed {
    background: rgba(0, 0, 0, 0.15);
}

/* ===== 内容区域 ===== */
