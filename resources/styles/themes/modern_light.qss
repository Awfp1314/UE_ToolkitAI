}

#EditAssetInput:focus {
    background-color: rgba(0, 0, 0, 0.12);
    border: none;
    outline: none;
}

#EditAssetInput::placeholder {
    color: rgba(0, 0, 0, 0.3);
}

/* ===== 分类选择�?===== */
#EditAssetCategoryCombo {
    background-color: rgba(0, 0, 0, 0.08);
    border: none;
    border-radius: 8px;
    padding: 0 16px;
    color: #1a1a1a;
    font-size: 14px;
}

#EditAssetCategoryCombo:hover {
    background-color: rgba(0, 0, 0, 0.12);
