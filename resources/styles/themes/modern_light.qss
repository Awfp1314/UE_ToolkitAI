    border: none;
}

#AssetSortCombo:focus {
    background-color: #eeeeee;
    border: none;
    outline: none;
}

#AssetSortCombo::drop-down {
    border: none;
    width: 0px;
}

#AssetSortCombo::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
}

#AssetSortCombo QAbstractItemView {
    background-color: #f5f5f5;
