/* ===== asset_manager\project_search_window.qss ===== */

/* ========================================
   工程搜索窗口样式
   ======================================== */

/* ===== 主容�?===== */
#ProjectSearchContainer {
    background: #ffffff;
    border-radius: 0px;
    border: 1px solid rgba(0, 0, 0, 0.2);
}

/* ===== 标题�?===== */
#ProjectSearchTitleBar {
    background: rgba(0, 0, 0, 0.08);
}

#ProjectSearchTitleText {
    color: #1a1a1a;
}

/* 标题栏按�?*/
#ProjectSearchThemeButton,
#ProjectSearchMinButton,
#ProjectSearchMaxButton {
    background: transparent;
    border: none;
    border-radius: 6px;
    color: rgba(0, 0, 0, 0.7);
    font-size: 18px;
}

#ProjectSearchThemeButton:hover,
#ProjectSearchMinButton:hover,
#ProjectSearchMaxButton:hover {
    background: rgba(0, 0, 0, 0.08);
}

#ProjectSearchCloseButton {
    background: transparent;
    border: none;
    border-radius: 6px;
    color: rgba(0, 0, 0, 0.7);
    font-size: 24px;
}

#ProjectSearchCloseButton:hover {
    background: #e81123;
    color: #ff6b6b;
}

/* ===== 过滤区域 ===== */
#ProjectSearchFilterArea {
    background: transparent;
}

/* 搜索�?*/
#ProjectSearchInput {
    background: #f5f5f5;
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    color: #1a1a1a;
    font-size: 14px;
}

#ProjectSearchInput:focus {
    background: #eeeeee;
}

#ProjectSearchInput::placeholder {
    color: rgba(0, 0, 0, 0.4);
}

/* 版本和排序下拉框 */
#ProjectSearchVersionFilter,
#ProjectSearchSortCombo {
    background: #f5f5f5;
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    color: #1a1a1a;
    font-size: 14px;
    text-align: center;
}

#ProjectSearchVersionFilter:hover,
#ProjectSearchSortCombo:hover {
    background: #eeeeee;
}

#ProjectSearchVersionFilter:focus,
#ProjectSearchSortCombo:focus {
    background: #eeeeee;
    outline: none;
}

#ProjectSearchVersionFilter::drop-down,
#ProjectSearchSortCombo::drop-down {
    border: none;
    width: 0px;
}

#ProjectSearchVersionFilter::down-arrow,
#ProjectSearchSortCombo::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
}

/* 下拉列表 */
#ProjectSearchVersionFilter QAbstractItemView,
#ProjectSearchSortCombo QAbstractItemView {
    background: #f5f5f5;
    border: 1px solid rgba(0, 0, 0, 0.15);
    padding: 4px;
    outline: none;
    selection-background-color: #4a9eff;
    selection-color: #1a1a1a;
}

#ProjectSearchVersionFilter QAbstractItemView::item,
#ProjectSearchSortCombo QAbstractItemView::item {
    height: 32px;
    padding: 4px 12px;
    border-radius: 4px;
    color: #1a1a1a;
}

#ProjectSearchVersionFilter QAbstractItemView::item:hover,
#ProjectSearchSortCombo QAbstractItemView::item:hover {
    background: rgba(0, 0, 0, 0.08);
}

#ProjectSearchVersionFilter QAbstractItemView::item:selected,
#ProjectSearchSortCombo QAbstractItemView::item:selected {
    background: #4a9eff;
    color: #1a1a1a;
}

/* 刷新按钮 */
#ProjectSearchRefreshButton {
    background: #f5f5f5;
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 500;
}

#ProjectSearchRefreshButton:hover {
    background: #eeeeee;
}

#ProjectSearchRefreshButton:pressed {
    background: rgba(0, 0, 0, 0.15);
}

/* 结果统计标签 */
#ProjectSearchResultLabel {
    color: rgba(0, 0, 0, 0.55);
    font-size: 12px;
}

/* ===== 滚动区域 ===== */
#ProjectSearchScrollArea {
    background: transparent;
    border: none;
}

#ProjectSearchScrollArea QScrollBar:vertical {
    background: rgba(0, 0, 0, 0.05);
    width: 8px;
    border-radius: 4px;
}

#ProjectSearchScrollArea QScrollBar::handle:vertical {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
    min-height: 20px;
}

#ProjectSearchScrollArea QScrollBar::handle:vertical:hover {
    background: rgba(0, 0, 0, 0.3);
}

#ProjectSearchScrollArea QScrollBar::add-line:vertical,
#ProjectSearchScrollArea QScrollBar::sub-line:vertical {
    height: 0px;
}

#ProjectSearchScrollArea QScrollBar::add-page:vertical,
#ProjectSearchScrollArea QScrollBar::sub-page:vertical {
    background: none;
}

/* 工程列表容器 */
#ProjectSearchList {
    background: transparent;
}

/* ===== 工程卡片 ===== */
#ProjectCard {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff,
        stop:0.33 #fafafa,
        stop:0.66 #f5f5f5,
        stop:1 #f8f9fa
    );
    border: 1px solid #e8e8e8;
    border-radius: 0px;
}

#ProjectCard:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff,
        stop:0.33 #fefefe,
        stop:0.66 #fcfcfc,
        stop:1 #fafafa
    );
    border: 1px solid rgba(0, 0, 0, 0.4);
}

/* 卡片缩略图区�?*/
#ProjectCardThumb {
    background: rgba(0, 0, 0, 0.08);
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
}

/* 卡片信息区域 */
#ProjectCardInfo {
    background: transparent;
}

/* 卡片工程名称 */
#ProjectCardName {
    color: #1a1a1a;
}

/* 卡片修改时间 */
#ProjectCardTime {
    color: rgba(0, 0, 0, 0.55);
}

/* 卡片导入按钮 */
#ProjectCardImportButton {
    background: rgba(0, 0, 0, 0.08);
    color: rgba(0, 0, 0, 0.8);
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 11px;
    padding: 8px 12px;
    outline: none;
}

#ProjectCardImportButton:hover {
    background: rgba(0, 0, 0, 0.15);
    color: #1a1a1a;
}

#ProjectCardImportButton:pressed {
    background: rgba(0, 0, 0, 0.20);
    padding-top: 9px;
    padding-bottom: 7px;
}

#ProjectCardImportButton:focus {
    outline: none;
}


/* ===== config_tool\config_tool.qss ===== */

/* ===== 工程配置界面样式 ===== */

/* 主容�?*/
#ConfigToolUI {
    background-color: #ffffff;
}

/* 标题 */
#ConfigToolTitle {
    color: #1a1a1a;
}

/* 添加按钮 */
#ConfigToolAddBtn {
    background-color: #f0f0f0;
    color: #1a1a1a;
    border: none;
    border-radius: 6px;
    padding: 8px 20px;
    font-size: 13px;
    font-weight: bold;
}

#ConfigToolAddBtn:hover {
    background-color: rgba(0, 0, 0, 0.08);
}

#ConfigToolAddBtn:pressed {
    background-color: rgba(0, 0, 0, 0.15);
}

/* 分隔�?*/
#ConfigToolSeparator {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 transparent,
        stop:0.5 rgba(74, 158, 255, 0.3),
        stop:1 transparent
    );
    border: none;
}

/* 滚动区域 */
#ConfigToolScroll {
    background-color: transparent;
    border: none;
}

#ConfigToolContent {
    background-color: transparent;
}

/* 空状态标�?*/
#ConfigToolEmptyLabel {
    color: rgba(0, 0, 0, 0.3);
    font-size: 16px;
}

/* ===== 配置模板卡片 ===== */
#ConfigTemplateCard {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff,
        stop:0.3 #fafafa,
        stop:0.7 #f5f5f5,
        stop:1 #f8f9fa
    );
    border: 1px solid #e8e8e8;
    border-radius: 8px;
}

#ConfigTemplateCard:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff,
        stop:0.3 #fefefe,
        stop:0.7 #fcfcfc,
        stop:1 #fafafa
    );
    border: 1px solid rgba(74, 158, 255, 0.5);
}

/* 卡片名称 */
#ConfigTemplateCardName {
    color: #1a1a1a;
}

/* 卡片描述 */
#ConfigTemplateCardDesc {
    color: rgba(0, 0, 0, 0.55);
    font-size: 11px;
}

/* 卡片信息 */
#ConfigTemplateCardInfo {
    color: rgba(0, 0, 0, 0.3);
    font-size: 10px;
}

/* 右键菜单 */
#ConfigTemplateCardMenu {
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 6px;
    padding: 5px;
}

#ConfigTemplateCardMenu::item {
    color: rgba(0, 0, 0, 0.85);
    padding: 8px 20px;
    border-radius: 4px;
}

#ConfigTemplateCardMenu::item:selected {
    background-color: rgba(0, 0, 0, 0.1);
}

#ConfigTemplateCardMenu::separator {
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
    margin: 5px 10px;
}


/* ===== site_recommendations\site_recommendations.qss ===== */

/* ===== 作者推荐界面样�?===== */

/* 主容�?*/
#SiteRecommendationsUI {
    background-color: #ffffff;
}

/* 描述文字 */
#SiteRecommendationsDesc {
    color: rgba(0, 0, 0, 0.7);
    font-size: 14px;
    padding: 5px 0;
}

/* 分隔�?*/
#SiteRecommendationsSeparator {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 transparent,
        stop:0.5 rgba(74, 158, 255, 0.3),
        stop:1 transparent
    );
    border: none;
}

/* 滚动区域 */
#SiteRecommendationsScroll {
    background-color: transparent;
    border: none;
}

#SiteRecommendationsContent {
    background-color: transparent;
}

/* 分类标题 */
#SiteRecommendationsCategoryLabel {
    color: #1a1a1a;
    padding: 8px 0 4px 0;
}

/* 卡片容器 */
#SiteRecommendationsCardsContainer {
    background-color: transparent;
}

/* ===== 站点卡片 ===== */
#SiteCard {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff,
        stop:0.3 #fafafa,
        stop:0.7 #f5f5f5,
        stop:1 #f8f9fa
    );
    border: 1px solid #e8e8e8;
    border-radius: 8px;
}

#SiteCard:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff,
        stop:0.3 #fefefe,
        stop:0.7 #fcfcfc,
        stop:1 #fafafa
    );
    border: 1px solid rgba(74, 158, 255, 0.5);
}

/* 卡片名称 */
#SiteCardName {
    color: #1a1a1a;
}

/* 卡片描述 */
#SiteCardDesc {
    color: rgba(0, 0, 0, 0.55);
    font-size: 11px;
}


/* ========================================
   复选框样式 - QCheckBox
   ======================================== */

QCheckBox {
    color: #1a1a1a;
    font-size: 13px;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border: none;
    background: rgba(0, 0, 0, 0.15);
}

QCheckBox::indicator:hover {
    background: rgba(0, 0, 0, 0.2);
}

QCheckBox::indicator:checked {
    border: none;
    background: qradialgradient(
        cx:0.5, cy:0.5, radius:0.5,
        fx:0.5, fy:0.5,
        stop:0 #4a9eff,
        stop:0.45 #4a9eff,
        stop:0.5 rgba(0, 0, 0, 0.15),
        stop:1 rgba(0, 0, 0, 0.15)
    );
}

QCheckBox::indicator:disabled {
    border: none;
    background: rgba(0, 0, 0, 0.08);
}

QCheckBox:disabled {
    color: #999999;
}

/* ========================================
   设置页面字体优化
   ======================================== */

/* 分组标题（如"主题设置"�?关闭方式设置"�?*/
#SubSectionLabel {
    color: #4a9eff;
    font-size: 14px;
    font-weight: bold;
    padding: 8px 0px 4px 0px;
}

/* 选项标签（如"默认主题"�?悬浮�?�?*/
#SettingLabel {
    color: #1a1a1a;
    font-size: 12px;
    font-weight: normal;
}

/* 说明文字（灰色小字） */
#DescriptionLabel {
    color: rgba(0, 0, 0, 0.5);
    font-size: 10px;
    line-height: 1.4;
}


/* ========================================
   资产管理器工具栏样式
   ======================================== */

/* 筛选标签 */
#AssetFilterLabel {
    color: rgba(0, 0, 0, 0.7);
    font-size: 13px;
    font-weight: 500;
    padding-right: 5px;
}

/* 分类筛选下拉框 */
#AssetCategoryFilter {
    background-color: #f5f5f5;
    border: none;
    border-radius: 6px;
    padding: 0 12px;
    color: #1a1a1a;
    font-size: 13px;
    text-align: center;
}

#AssetCategoryFilter:hover {
    background-color: rgba(0, 0, 0, 0.08);
}

#AssetCategoryFilter:focus {
    background-color: rgba(0, 0, 0, 0.12);
    outline: none;
}

#AssetCategoryFilter::drop-down {
    border: none;
    width: 20px;
}

#AssetCategoryFilter::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
}

#AssetCategoryFilter QAbstractItemView {
    background-color: #f5f5f5;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 4px;
    padding: 4px;
    outline: none;
    selection-background-color: #4a9eff;
    selection-color: #ffffff;
}

#AssetCategoryFilter QAbstractItemView::item {
    padding: 8px 12px;
    border-radius: 4px;
    min-height: 28px;
}

#AssetCategoryFilter QAbstractItemView::item:hover {
    background-color: rgba(0, 0, 0, 0.08);
}

#AssetCategoryFilter QAbstractItemView::item:selected {
    background-color: #4a9eff;
    color: #ffffff;
}

