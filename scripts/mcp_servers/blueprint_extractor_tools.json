[
  {
    "name": "ExtractBlueprint",
    "description": "提取指定路径蓝图的完整结构信息，包括变量、函数、图表节点等。用于分析蓝图逻辑和结构。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "AssetPath": {
          "type": "string",
          "description": "蓝图资产路径，如 /Game/Blueprints/BP_Character"
        }
      },
      "required": ["AssetPath"]
    }
  },
  {
    "name": "ExtractWidgetBlueprint",
    "description": "提取 UMG Widget 蓝图的结构信息，包括控件树、变量、函数等。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "AssetPath": {
          "type": "string",
          "description": "Widget 蓝图资产路径，如 /Game/UI/WBP_MainMenu"
        }
      },
      "required": ["AssetPath"]
    }
  },
  {
    "name": "GetEditorContext",
    "description": "获取当前 UE 编辑器的上下文信息，包括项目名称、引擎版本、当前打开的资产、PIE 状态、资产统计等。可用于获取当前打开的蓝图路径。",
    "inputSchema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "ListAssets",
    "description": "列出指定目录下的资产。支持递归列出子目录，支持按类型过滤。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "PackagePath": {
          "type": "string",
          "description": "资产目录路径，如 /Game/Blueprints"
        },
        "bRecursive": {
          "type": "boolean",
          "description": "是否递归列出子目录（默认 false）"
        },
        "ClassFilter": {
          "type": "string",
          "description": "资产类型过滤，如 Blueprint、WidgetBlueprint、Material 等（可选）"
        }
      },
      "required": ["PackagePath"]
    }
  }
]
